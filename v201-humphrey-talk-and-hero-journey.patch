   .card > * { position: relative; z-index: 1; }
 
@@ -724,12 +730,28 @@
         card.style.setProperty('--char-color', c.color);
         card.style.animationDelay = (idx * 0.1) + 's';
 
+        // v201: status badge reflects the ACTUAL chapter state, fixing the
+        // contradiction where a card showed "EARNED" while still asking for
+        // more plays. Three honest states:
+        //   - not discovered  -> 🔒 LOCKED
+        //   - discovered 1-2  -> CHAPTER N/3 (in progress, NOT "earned")
+        //   - all 3 chapters  -> ★ SQUAD READY (fully earned)
+        let badgeHtml;
+        if (!isDiscovered) {
+          badgeHtml = '<span class="hh-badge hh-badge--locked">\uD83D\uDD12 LOCKED</span>';
+        } else if (isSquadReady) {
+          badgeHtml = '<span class="hh-badge hh-badge--complete">\u2605 SQUAD READY</span>';
+        } else {
+          badgeHtml = '<span class="hh-badge hh-badge--progress">CHAPTER ' + ep + '/3</span>';
+        }
+
         const pips =
           '<div class="episode-pips">' +
           [1, 2, 3].map(n => `<div class="pip${ep >= n ? ' filled' : ''}"></div>`).join('') +
           '</div>';
 
         card.innerHTML = `
+          ${badgeHtml}
           <div class="art">
             <span class="main">${isDiscovered ? c.emoji : '❓'}</span>
             ${isDiscovered && c.accessory ? `<span class="acc">${c.accessory}</span>` : ''}
@@ -747,12 +769,54 @@
         `;
         if (isDiscovered) {
           card.addEventListener('click', () => openModal(c, ep));
+        } else {
+          // v201: locked cards aren't dead — a tap shows a friendly nudge
+          // telling Nigel exactly how to earn this hero.
+          card.addEventListener('click', () => showLockToast(c));
         }
         grid.appendChild(card);
       });
 
+      // v201: friendly "not earned yet" nudge for locked character cards.
+      let _lockToastEl = null, _lockToastTimer = null;
+      function showLockToast(c) {
+        var firstStep = '';
+        try {
+          if (canDescribe) {
+            var n = NS3.describeNextStep(c.id, milestones, 0);
+            if (n && n.label) firstStep = n.label;
+          }
+        } catch (_) {}
+        if (!firstStep) firstStep = hintFor(c.zones);
+        if (!_lockToastEl) {
+          _lockToastEl = document.createElement('div');
+          _lockToastEl.className = 'hh-toast';
+          document.body.appendChild(_lockToastEl);
+        }
+        _lockToastEl.innerHTML =
+          '<span class="hh-toast-emoji">\uD83D\uDD12</span>' +
+          'Keep playing to meet this hero!<br><strong>' + firstStep + '</strong> to unlock them.';
+        // reflow then show
+        void _lockToastEl.offsetWidth;
+        _lockToastEl.classList.add('show');
+        if (_lockToastTimer) clearTimeout(_lockToastTimer);
+        _lockToastTimer = setTimeout(function () {
+          if (_lockToastEl) _lockToastEl.classList.remove('show');
+        }, 3200);
+        // Ms. Humphrey says it too, if she's available.
+        try {
+          var H = window.HeroAcademy && window.HeroAcademy.Humphrey;
+          if (H && typeof H.say === 'function') {
+            H.say('hero-hall-locked', {
+              kidName: 'Nigel',
+              text: "You haven't met this hero yet, Nigel. " + firstStep + " to unlock them!",
+              expression: 'encouraging',
+            });
+          }
+        } catch (_) {}
+      }
+
       // Modal
-      const modalBg = document.getElementById('modal-bg');
       const modal   = document.getElementById('modal');
       async function openModal(c, ep) {
         ep = ep || 0;
