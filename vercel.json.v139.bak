{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "crons": [
    {
      "path": "/api/cron/saturday-email",
      "schedule": "0 12 * * 6"
    },
    {
      "path": "/api/cron/healthcheck",
      "schedule": "0 */6 * * *"
    },
    {
      "path": "/api/cron/monthly-video-curation",
      "schedule": "0 13 1 * *"
    },
    {
      "path": "/api/cron/generate-daily-content",
      "schedule": "0 9 * * *"
    },
    {
      "path": "/api/cron/generate-expedition",
      "schedule": "30 8 * * *"
    }
  ]
}
